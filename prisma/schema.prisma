generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────
// USERS & AUTH (NextAuth v5 compatible)
// ─────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String? // bcrypt hashed
  image         String?
  emailVerified DateTime?
  role          UserRole  @default(USER)

  businesses   Business[]
  subscription Subscription?
  accounts     Account[]
  sessions     Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([email])
}

// ─────────────────────────────────────────
// SUBSCRIPTIONS & PLANS
// ─────────────────────────────────────────

model Subscription {
  id     String   @id @default(cuid())
  userId String   @unique
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   PlanType  @default(FREE)
  status SubStatus @default(ACTIVE)

  // Stripe
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  trialEnd             DateTime?
  cancelledAt          DateTime?
  cancelReason         String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

// ─────────────────────────────────────────
// BUSINESSES (multi-tenant)
// ─────────────────────────────────────────

model Business {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String? @db.Text
  shortDesc    String?
  businessType String? // restaurant, salon, boulangerie, etc.

  // Coordonnées
  address String?
  city    String?
  zipCode String?
  country String  @default("FR")
  phone   String?
  email   String?
  website String?

  // Branding
  logoUrl        String?
  logoBackground String? // Couleur de fond derrière le logo (hex), auto-détectée ou manuelle
  coverUrl       String?
  primaryColor   String  @default("#4f46e5")
  secondaryColor String  @default("#312e81")
  accentColor    String  @default("#f59e0b")
  fontFamily     String  @default("Plus Jakarta Sans")

  // Réseaux sociaux
  facebookUrl  String?
  instagramUrl String?
  googleMapsUrl String? @db.Text

  // Statut
  isPublished Boolean   @default(false)
  deletedAt   DateTime?

  // Prise en main par le prospect
  claimToken   String?   @unique
  claimedAt    DateTime?
  prospectedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relations modules
  modules          BusinessModule[]
  bookingConfig    BookingConfig?
  reviewConfig     ReviewConfig?
  loyaltyConfig    LoyaltyConfig?
  bookings         Booking[]
  reviews          Review[]
  loyaltyCards     LoyaltyCard[]
  loyaltyStatuses  LoyaltyStatus[]
  showcaseBlocks   ShowcaseBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessModule {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  module     ModuleType
  isActive   Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, module])
}

enum ModuleType {
  SHOWCASE
  BOOKING
  REVIEWS
  LOYALTY
  SOCIAL
  ECOMMERCE
  PHONE_AI
  STAFF
  INVOICING
}

// ─────────────────────────────────────────
// MODULE RÉSERVATIONS
// ─────────────────────────────────────────

enum BookingMode {
  APPOINTMENT // RDV classique (coiffeur, médecin…)
  TABLE       // Réservation de table (restaurant…)
  CLASS       // Cours / activité (fitness, atelier…)
}

model BookingConfig {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Mode de réservation
  mode BookingMode @default(APPOINTMENT)

  // Horaires
  openTime  String @default("09:00")
  closeTime String @default("18:00")
  workDays  Json   @default("[1,2,3,4,5]") // 0=Dim, 1=Lun…6=Sam

  // Paramètres
  defaultDuration Int  @default(60)  // minutes par défaut (et durée repas/cours)
  slotInterval    Int?               // minutes entre créneaux (null = defaultDuration)
  maxPerSlot      Int?               // max réservations par créneau (null = illimité)
  bufferTime      Int  @default(15)  // minutes entre rendez-vous (mode APPOINTMENT)
  maxAdvanceDays  Int  @default(30)
  minAdvanceHours Int  @default(2)

  // Champs libres pour le formulaire client
  extraFields Json? // [{ key, label, type, required }]

  // Message de confirmation
  confirmationMsg String? @db.Text

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id              String        @id @default(cuid())
  bookingConfigId String
  bookingConfig   BookingConfig @relation(fields: [bookingConfigId], references: [id], onDelete: Cascade)

  name        String
  description String?
  duration    Int?    // minutes (null = durée variable / hérite du defaultDuration)
  price       Float?
  isActive    Boolean @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  serviceId  String?
  service    Service? @relation(fields: [serviceId], references: [id])

  customerName  String
  customerEmail String
  customerPhone String?

  date       DateTime
  endDate    DateTime?
  status     BookingStatus @default(PENDING)
  notes      String?       @db.Text
  guestCount Int?          // nombre de couverts / participants (TABLE, CLASS)
  customData Json?         // champs libres renseignés par le client

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ─────────────────────────────────────────
// MODULE AVIS GOOGLE + ROULETTE
// ─────────────────────────────────────────

model ReviewConfig {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  googleUrl    String? @db.Text // Lien direct vers la page avis Google
  instructions String? @db.Text

  rewards Reward[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reward {
  id             String       @id @default(cuid())
  reviewConfigId String
  reviewConfig   ReviewConfig @relation(fields: [reviewConfigId], references: [id], onDelete: Cascade)

  name        String
  description String?
  probability Float   @default(0.1) // 0.0 à 1.0 (somme = 1.0)
  color       String  @default("#4f46e5")
  emoji       String  @default("🎁")
  isActive    Boolean @default(true)
  expiryDays  Int     @default(30)

  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id             String        @id @default(cuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id])
  reviewConfigId String?
  reviewConfig   ReviewConfig? @relation(fields: [reviewConfigId], references: [id])

  // Infos client (facultatif)
  customerName  String?
  customerEmail String?
  customerPhone String?

  // Suivi de l'avis
  token                   String   @unique @default(cuid())
  googleReviewInitiated   Boolean  @default(false)
  googleReviewInitiatedAt DateTime?

  // Récompense
  rewardId        String?
  reward          Reward?  @relation(fields: [rewardId], references: [id])
  rewardCode      String?  @unique
  rewardClaimed   Boolean  @default(false)
  rewardClaimedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// MODULE CARTE DE FIDÉLITÉ
// ─────────────────────────────────────────

model LoyaltyConfig {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Design de la carte
  cardColor     String @default("#4f46e5")
  cardTextColor String @default("#ffffff")
  stampColor    String @default("#f59e0b")
  stampIcon     String @default("⭐")

  // Programme
  stampsRequired    Int    @default(10)
  rewardName        String @default("Un produit offert")
  rewardDescription String?

  // Expiration des tampons (null = pas d'expiration)
  stampExpiryDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyCard {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  customerName  String
  customerEmail String?
  customerPhone String?

  qrCode String @unique @default(cuid())

  // Compteurs lifetime (ne diminuent jamais)
  totalStamps  Int @default(0)
  totalRewards Int @default(0)

  // Compteur du cycle actuel (repart à 0 sur reset merchant)
  currentStamps Int @default(0)
  resetCount    Int @default(0)

  // Pour le calcul d'inactivité des statuts
  lastActivityAt DateTime?

  stamps LoyaltyStamp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, customerEmail])
}

// Statuts client configurables par le commerçant
model LoyaltyStatus {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name           String
  emoji          String  @default("⭐")
  color          String  @default("#6366f1")
  minRewards     Int     @default(1)   // Nb de récompenses lifetime minimum
  extraReward    String? @db.Text      // Texte libre d'avantage supplémentaire
  inactivityDays Int?                  // Jours sans activité → perte du statut (null = jamais)
  order          Int     @default(0)   // Ordre croissant (le plus haut = meilleur statut)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyStamp {
  id     String      @id @default(cuid())
  cardId String
  card   LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  isReward Boolean @default(false) // true = tampon de récompense
  notes    String?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// MODULE SITE VITRINE — BLOCS CONFIGURABLES
// ─────────────────────────────────────────

enum ShowcaseBlockType {
  HERO
  ABOUT
  SERVICES
  BOOKING_CTA
  LOYALTY_CTA
  REVIEWS_CTA
  CONTACT
  HOURS
  BANNER
  SOCIAL
  FAQ
}

model ShowcaseBlock {
  id         String            @id @default(cuid())
  businessId String
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type     ShowcaseBlockType
  isActive Boolean           @default(true)
  order    Int               @default(0)
  content  Json              @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// LOGS
// ─────────────────────────────────────────

enum LogLevel {
  INFO
  WARN
  ERROR
}

model Log {
  id        String   @id @default(cuid())
  level     LogLevel @default(INFO)
  action    String
  userId    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// CONTACT
// ─────────────────────────────────────────

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
