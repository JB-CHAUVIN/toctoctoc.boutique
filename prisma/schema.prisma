generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────
// USERS & AUTH (NextAuth v5 compatible)
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String? // bcrypt hashed
  image         String?
  emailVerified DateTime?

  businesses   Business[]
  subscription Subscription?
  accounts     Account[]
  sessions     Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// SUBSCRIPTIONS & PLANS
// ─────────────────────────────────────────

model Subscription {
  id     String   @id @default(cuid())
  userId String   @unique
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   PlanType  @default(FREE)
  status SubStatus @default(ACTIVE)

  // Stripe (préparé, pas encore actif)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

// ─────────────────────────────────────────
// BUSINESSES (multi-tenant)
// ─────────────────────────────────────────

model Business {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String? @db.Text
  shortDesc    String?
  businessType String? // restaurant, salon, boulangerie, etc.

  // Coordonnées
  address String?
  city    String?
  zipCode String?
  country String  @default("FR")
  phone   String?
  email   String?
  website String?

  // Branding
  logoUrl        String?
  coverUrl       String?
  primaryColor   String  @default("#4f46e5")
  secondaryColor String  @default("#312e81")
  accentColor    String  @default("#f59e0b")
  fontFamily     String  @default("Inter")

  // Réseaux sociaux
  facebookUrl  String?
  instagramUrl String?
  googleMapsUrl String?

  // Statut
  isPublished Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relations modules
  modules       BusinessModule[]
  bookingConfig BookingConfig?
  reviewConfig  ReviewConfig?
  loyaltyConfig LoyaltyConfig?
  bookings      Booking[]
  reviews       Review[]
  loyaltyCards  LoyaltyCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessModule {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  module     ModuleType
  isActive   Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, module])
}

enum ModuleType {
  SHOWCASE
  BOOKING
  REVIEWS
  LOYALTY
  SOCIAL
  ECOMMERCE
  PHONE_AI
  STAFF
  INVOICING
}

// ─────────────────────────────────────────
// MODULE RÉSERVATIONS
// ─────────────────────────────────────────

model BookingConfig {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Horaires
  openTime  String @default("09:00")
  closeTime String @default("18:00")
  workDays  Json   @default("[1,2,3,4,5]") // 0=Dim, 1=Lun…6=Sam

  // Paramètres
  defaultDuration Int @default(60) // minutes
  bufferTime      Int @default(15) // minutes entre rendez-vous
  maxAdvanceDays  Int @default(30)
  minAdvanceHours Int @default(2)

  // Message de confirmation
  confirmationMsg String? @db.Text

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id              String        @id @default(cuid())
  bookingConfigId String
  bookingConfig   BookingConfig @relation(fields: [bookingConfigId], references: [id], onDelete: Cascade)

  name        String
  description String?
  duration    Int // minutes
  price       Float?
  isActive    Boolean @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  serviceId  String?
  service    Service? @relation(fields: [serviceId], references: [id])

  customerName  String
  customerEmail String
  customerPhone String?

  date    DateTime
  endDate DateTime?
  status  BookingStatus @default(PENDING)
  notes   String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ─────────────────────────────────────────
// MODULE AVIS GOOGLE + ROULETTE
// ─────────────────────────────────────────

model ReviewConfig {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  googleUrl    String? // Lien direct vers la page avis Google
  instructions String? @db.Text

  rewards Reward[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reward {
  id             String       @id @default(cuid())
  reviewConfigId String
  reviewConfig   ReviewConfig @relation(fields: [reviewConfigId], references: [id], onDelete: Cascade)

  name        String
  description String?
  probability Float   @default(0.1) // 0.0 à 1.0 (somme = 1.0)
  color       String  @default("#4f46e5")
  emoji       String  @default("🎁")
  isActive    Boolean @default(true)
  expiryDays  Int     @default(30)

  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id             String        @id @default(cuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id])
  reviewConfigId String?
  reviewConfig   ReviewConfig? @relation(fields: [reviewConfigId], references: [id])

  // Infos client (facultatif)
  customerName  String?
  customerEmail String?
  customerPhone String?

  // Suivi de l'avis
  token                   String   @unique @default(cuid())
  googleReviewInitiated   Boolean  @default(false)
  googleReviewInitiatedAt DateTime?

  // Récompense
  rewardId        String?
  reward          Reward?  @relation(fields: [rewardId], references: [id])
  rewardCode      String?  @unique
  rewardClaimed   Boolean  @default(false)
  rewardClaimedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// MODULE CARTE DE FIDÉLITÉ
// ─────────────────────────────────────────

model LoyaltyConfig {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // Design de la carte
  cardColor     String @default("#4f46e5")
  cardTextColor String @default("#ffffff")
  stampColor    String @default("#f59e0b")
  stampIcon     String @default("⭐")

  // Programme
  stampsRequired    Int    @default(10)
  rewardName        String @default("Un produit offert")
  rewardDescription String?

  // Expiration des tampons (null = pas d'expiration)
  stampExpiryDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyCard {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  customerName  String
  customerEmail String?
  customerPhone String?

  qrCode String @unique @default(cuid())

  totalStamps  Int @default(0)
  totalRewards Int @default(0)

  stamps LoyaltyStamp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, customerEmail])
}

model LoyaltyStamp {
  id     String      @id @default(cuid())
  cardId String
  card   LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  isReward Boolean @default(false) // true = tampon de récompense
  notes    String?

  createdAt DateTime @default(now())
}
